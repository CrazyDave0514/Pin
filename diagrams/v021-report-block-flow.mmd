flowchart TD
    subgraph 作品举报
        A[作品详情页] --> B[点击...更多按钮]
        B --> C[展开菜单]
        C --> D[点击举报]
        D --> E[弹出举报表单]
        E --> F[选择举报原因]
        F --> G{原因?}
        G -->|抄袭/侵权| H1[抄袭/侵权]
        G -->|色情低俗| H2[色情低俗]
        G -->|垃圾广告| H3[垃圾广告]
        G -->|违法违规| H4[违法违规]
        G -->|其他| H5[其他]
        H1 --> I[补充说明可选]
        H2 --> I
        H3 --> I
        H4 --> I
        H5 --> I
        I --> J[点击提交]
        J --> K{提交结果}
        K -->|成功| L[Toast:举报成功]
        K -->|失败| M[Toast:错误信息]
        L --> N[关闭弹窗]
        M --> E
    end
    
    subgraph 作者拉黑
        A --> O[点击拉黑按钮]
        O --> P[确认弹窗]
        P --> Q{确认?}
        Q -->|取消| A
        Q -->|确认| R[调用拉黑接口]
        R --> S{结果}
        S -->|成功| T[Toast:已拉黑]
        S -->|失败| U[Toast:错误信息]
        T --> V[自动解除关注]
        V --> W[首页刷新过滤]
        U --> A
    end
    
    subgraph 黑名单管理
        X[设置页] --> Y[点击黑名单管理]
        Y --> Z[黑名单列表页]
        Z --> AA{有黑名单?}
        AA -->|有| AB[展示拉黑列表]
        AA -->|无| AC[展示空状态]
        AB --> AD[点击移除按钮]
        AD --> AE[确认弹窗]
        AE --> AF{确认?}
        AF -->|取消| Z
        AF -->|确认| AG[调用移除接口]
        AG --> AH[列表刷新]
        AH --> AA
    end
    
    style A fill:#e3f2fd
    style L fill:#e8f5e9
    style T fill:#e8f5e9
    style Z fill:#fff3e0
