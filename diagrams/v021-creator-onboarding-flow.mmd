flowchart TD
    subgraph 创作者主页
        A[作品详情页] --> B[点击创作者头像/昵称]
        B --> C[跳转创作者主页]
        C --> D{是否本人?}
        D -->|是| E[隐藏关注/拉黑按钮]
        D -->|否| F[展示关注/拉黑按钮]
        
        E --> G[展示创作者信息]
        F --> G
        G --> H[头像+昵称+简介]
        H --> I[统计栏:作品数/粉丝/关注]
        I --> J[Tab栏:作品]
        J --> K[作品瀑布流]
        
        F --> L[点击关注]
        L --> M{当前状态}
        M -->|未关注| N[调用关注接口]
        M -->|已关注| O[调用取消关注]
        N --> P[按钮变已关注]
        O --> Q[按钮变关注]
        
        F --> R[点击拉黑]
        R --> S[确认弹窗]
        S --> T{确认?}
        T -->|取消| C
        T -->|确认| U[调用拉黑接口]
        U --> V[Toast:已拉黑]
        V --> W[自动解除关注]
        W --> X[按钮变已拉黑]
    end
    
    subgraph 新手引导
        Y[首次登录/注册成功] --> Z[自动触发引导]
        Z --> AA[步骤1:首页社区]
        AA --> AB["这里可以浏览其他创作者的拼豆作品"]
        AB --> AC[下一步]
        AC --> AD[步骤2:项目Tab]
        AD --> AE["这里管理你的拼豆项目"]
        AE --> AF[下一步]
        AF --> AG[步骤3:创建入口]
        AG --> AH["支持新建/导入图片/导入图纸"]
        AH --> AI[下一步]
        AI --> AJ[步骤4:画布编辑器]
        AJ --> AK["选择颜色放置拼豆"]
        AK --> AL[下一步]
        AL --> AM[步骤5:发布作品]
        AM --> AN["完成创作后发布到社区"]
        AN --> AO[开始创作]
        AO --> AP[记录完成状态]
        AP --> Main[进入首页]
        
        AA --> AQ[点击跳过]
        AD --> AQ
        AG --> AQ
        AJ --> AQ
        AM --> AQ
        AQ --> AR{确认跳过?}
        AR -->|取消| AA
        AR -->|确认| Main
    end
    
    style C fill:#e3f2fd
    style G fill:#fff3e0
    style Z fill:#fce4ec
    style Main fill:#e8f5e9
