flowchart TD
    Start([打开应用]) --> CheckToken{检查本地Token}
    CheckToken -->|Token有效| AutoLogin[自动登录]
    CheckToken -->|Token无效/过期| LoginPage[登录页]
    
    LoginPage --> EmailInput[输入邮箱]
    EmailInput --> PasswordInput[输入密码]
    PasswordInput --> AgreementCheck{协议勾选?}
    AgreementCheck -->|未勾选| ShowAgreementModal[弹窗提示]
    ShowAgreementModal -->|确认| AutoCheck[自动勾选协议]
    ShowAgreementModal -->|取消| AgreementCheck
    AgreementCheck -->|已勾选| ClickLogin[点击登录]
    AutoCheck --> ClickLogin
    
    ClickLogin --> ValidateLogin{校验}
    ValidateLogin -->|成功| SaveToken[保存Token]
    ValidateLogin -->|失败| ShowLoginError[显示错误]
    ShowLoginError --> EmailInput
    
    SaveToken --> MainPage[首页]
    AutoLogin --> MainPage
    
    LoginPage --> RegisterLink[点击注册]
    RegisterLink --> RegisterPage[注册页]
    
    RegisterPage --> RegEmail[输入邮箱]
    RegEmail --> SendCode[点击获取验证码]
    SendCode --> CodeCountdown[60秒倒计时]
    CodeCountdown --> InputCode[输入验证码]
    InputCode --> ValidateCode{校验验证码}
    ValidateCode -->|失败| ShowCodeError[显示错误]
    ShowCodeError --> InputCode
    ValidateCode -->|成功| UnlockFields[解锁后续字段]
    
    UnlockFields --> InputNickname[输入昵称]
    InputNickname --> InputRegPassword[输入密码]
    InputRegPassword --> InputConfirmPwd[确认密码]
    InputConfirmPwd --> RegAgreement{协议勾选?}
    RegAgreement -->|未勾选| ShowRegAgreementModal[弹窗提示]
    ShowRegAgreementModal -->|确认| AutoRegCheck[自动勾选]
    ShowRegAgreementModal -->|取消| RegAgreement
    RegAgreement -->|已勾选| ClickRegister[点击注册]
    AutoRegCheck --> ClickRegister
    
    ClickRegister --> CreateUser[创建用户]
    CreateUser --> InitPoints[初始化100积分]
    InitPoints --> SaveToken
    
    LoginPage --> ForgotLink[忘记密码?]
    ForgotLink --> ForgotPage[忘记密码页]
    
    ForgotPage --> ForgotEmail[输入邮箱]
    ForgotEmail --> ForgotSendCode[获取验证码]
    ForgotSendCode --> ForgotInputCode[输入验证码]
    ForgotInputCode --> ValidateForgotCode{校验}
    ValidateForgotCode -->|失败| ShowForgotError[显示错误]
    ShowForgotError --> ForgotInputCode
    ValidateForgotCode -->|成功| ShowNewPwdFields[显示新密码区域]
    ShowNewPwdFields --> InputNewPwd[输入新密码]
    InputNewPwd --> InputNewPwdConfirm[确认新密码]
    InputNewPwdConfirm --> ClickReset[点击重置]
    ClickReset --> ResetSuccess[重置成功]
    ResetSuccess --> BackToLogin[返回登录页]
    
    MainPage --> Logout[退出登录]
    Logout --> ClearToken[清除Token]
    ClearToken --> LoginPage
    
    style Start fill:#e1f5fe
    style MainPage fill:#e8f5e9
    style SaveToken fill:#fff3e0
    style CreateUser fill:#fff3e0
    style RegisterPage fill:#fce4ec
    style ForgotPage fill:#fce4ec
